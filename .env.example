# Docket is offline by design. There are NO cloud API keys.
# The only configuration here governs how the local Ollama runtime is reached.

# Where the local Ollama server lives.
# In Tauri production: a unix socket managed by the Rust core.
# In browser dev: the local HTTP endpoint Ollama exposes by default.
OLLAMA_HOST=http://127.0.0.1:11434

# Default model for machines with >= 32GB RAM on M2 Pro or better.
DOCKET_MODEL_DEFAULT=qwen3:32b-q4_K_M

# Fallback model for machines with 16-31GB RAM.
DOCKET_MODEL_FALLBACK=qwen3:8b-q4_K_M

# Embedding model. v1.5 from Ollama's library. v2-moe lives on HuggingFace and
# would need a Modelfile shim — week-2+ work.
DOCKET_EMBED_MODEL=nomic-embed-text

# Reranker. Not wired in week 1 — Ollama doesn't serve cross-encoders. The
# week-2 sidecar will pick up BAAI/bge-reranker-v2-m3 directly from HF and
# read this var as the model name to load.
# DOCKET_RERANK_MODEL=bge-reranker-v2-m3

# Where matter data lives. In production, Tauri overrides this with
# ~/Library/Application Support/Docket/matters.
DOCKET_DATA_DIR=./data/matters

# Strict mode toggles the re-grounding aggressiveness.
# 'strict' drops more, 'lenient' keeps more. Defaults to 'balanced'.
DOCKET_GROUNDING_MODE=balanced
